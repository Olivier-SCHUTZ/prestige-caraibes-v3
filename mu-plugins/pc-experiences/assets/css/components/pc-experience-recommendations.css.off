/* ============================================================
   Composant : Experience Recommendations (Logements)
   Shortcode : [experience_logements_recommandes]
   ============================================================ */

.exp-reco-section {
  padding: 2rem 0;
}

.exp-reco-title {
  font-family: var(--pc-font-title);
  font-size: 1.8rem;
  text-align: center;
  margin-bottom: 2rem;
  color: var(--pc-color-heading);
}

.exp-reco-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 2rem;
}

.exp-reco-card {
  background: #ffffff;
  border-radius: var(--pc-radius, 10px);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  transition:
    transform 0.2s ease,
    box-shadow 0.2s ease;
  overflow: hidden;
}

.exp-reco-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 12px 30px rgba(0, 0, 0, 0.12);
}

.exp-reco-card-link {
  display: block;
  text-decoration: none;
  color: inherit;
}

.exp-reco-card-image {
  aspect-ratio: 16/10;
}

.exp-reco-card-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.exp-reco-card-content {
  padding: 1.25rem;
}

.exp-reco-card-title {
  font-family: var(--pc-font-title);
  font-size: 1.2rem;
  font-weight: 600;
  margin: 0 0 0.5rem 0;
  color: var(--pc-color-heading);
}

.exp-reco-card-price {
  font-size: 1rem;
  color: var(--pc-color-primary);
  font-weight: 500;
}
