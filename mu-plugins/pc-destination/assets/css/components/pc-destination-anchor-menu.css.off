/* ==========================================================================
   Destination — Anchor Menu (Navigation collante)
   ========================================================================== */

.dest-anchor-menu {
  position: sticky;
  top: 68px; /* Hauteur à ajuster selon ton header */
  z-index: 50;
  display: flex;
  align-items: center;
  gap: 6px;
  background: #f9f9f9;
  border-bottom: 1px solid #eaeaea;
  padding: 4px 8px;
}

/* Flèches de défilement (si utilisées en JS plus tard) */
.dest-anchor-arrow {
  flex-shrink: 0;
  background: transparent;
  border: 0;
  color: #0e2b5c;
  font-size: 1.5rem;
  line-height: 1;
  padding: 6px 8px;
  border-radius: 8px;
  cursor: pointer;
  user-select: none;
  transition: background-color 0.2s ease;
}

.dest-anchor-arrow:hover {
  background: rgba(0, 0, 0, 0.06);
}

.dest-anchor-arrow[disabled] {
  opacity: 0.3;
  cursor: default;
  background: transparent;
}

/* Conteneur défilant */
.dest-anchor-scroller {
  flex-grow: 1;
  overflow-x: auto;
  scrollbar-width: none; /* Firefox */
  -ms-overflow-style: none; /* IE/Edge */
}

.dest-anchor-scroller::-webkit-scrollbar {
  display: none; /* Chrome/Safari */
}

/* Navigation interne */
.dest-anchor-nav {
  display: inline-flex;
  gap: 0.25rem;
  padding: 0.5rem 0.25rem;
  white-space: nowrap;
}

.dest-anchor-nav a {
  display: inline-flex;
  padding: 10px 14px;
  border-radius: 12px;
  text-decoration: none;
  color: #0e2b5c;
  transition:
    background-color 0.2s ease,
    color 0.2s ease;
  font-family: var(--pc-font-title, inherit);
  font-size: var(--pc-btn-text-size, 1rem);
  font-weight: 500;
}

.dest-anchor-nav a:hover {
  background: rgba(0, 0, 0, 0.06);
}

.dest-anchor-nav a.is-active {
  background: #0e2b5c;
  color: #fff;
  font-weight: 600;
}
