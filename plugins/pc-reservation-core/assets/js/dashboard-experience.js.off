/**
 * PC Experience Dashboard (NEW)
 * 1 fichier, 4 endpoints AJAX: pc_experience_get_list/details/save/delete
 */
(function ($) {
  class PCExperienceDashboard {
    constructor() {
      this.ajaxUrl = (window.pcReservationVars && pcReservationVars.ajax_url) || "/wp-admin/admin-ajax.php";
      this.nonce = (window.pcReservationVars && pcReservationVars.nonce) || "";

      this.state = {
        page: 1,
        per_page: 20,
        search: "",
        status: "",
        availability: "",
      };

      this.current = null; // {id,...}

      this.$loading = $("#pc-experience-loading");
      this.$table = $("#pc-experience-table");
      this.$tbody = $("#pc-experience-table-body");
      this.$empty = $("#pc-experience-empty");
      this.$pagination = $("#pc-experience-pagination");

      this.$modal = $("#experience-modal");
      this.$modalLoading = $("#pc-experience-modal-loading");
      this.$modalDetails = $("#pc-experience-modal-details");
      this.$modalTitle = $("#pc-experience-modal-title");

      this.bind();
      this.loadList();
    }

    ajax(action, data) {
      return $.post(this.ajaxUrl, Object.assign({ action, nonce: this.nonce }, data || {}));
    }

    bind() {
      // Create
      $(document).on("click", "#pc-btn-add-experience", (e) => {
        e.preventDefault();
        this.openNew();
      });

      // Search / filters
      $(document).on(
        "input",
        "#pc-experience-search",
        this.debounce(() => {
          this.state.search = $("#pc-experience-search").val() || "";
          this.state.page = 1;
          this.loadList();
        }, 400),
      );

      $(document).on("change", "#pc-experience-status-filter", () => {
        this.state.status = $("#pc-experience-status-filter").val() || "";
        this.state.page = 1;
        this.loadList();
      });

      $(document).on("change", "#pc-experience-availability-filter", () => {
        this.state.availability = $("#pc-experience-availability-filter").val() || "";
        this.state.page = 1;
        this.loadList();
      });

      // Edit (row button)
      $(document).on("click", ".pc-btn-edit-experience", (e) => {
        e.preventDefault();
        const id = parseInt($(e.currentTarget).data("id"), 10);
        if (id) this.openEdit(id);
      });

      // Delete (row button)
      $(document).on("click", ".pc-btn-delete-experience", (e) => {
        e.preventDefault();
        const id = parseInt($(e.currentTarget).data("id"), 10);
        if (id) this.delete(id);
      });

      // Modal close
      $(document).on("click", "#pc-experience-modal-close, #pc-experience-cancel-btn", (e) => {
        e.preventDefault();
        this.closeModal();
      });
      $(document).on("click", ".pc-modal-overlay", () => this.closeModal());

      // Modal save/delete
      $(document).on("click", "#pc-experience-save-btn", (e) => {
        e.preventDefault();
        this.save();
      });
      $(document).on("click", "#pc-experience-delete-btn", (e) => {
        e.preventDefault();
        if (this.current && this.current.id) this.delete(this.current.id, true);
      });

      // Tabs
      $(document).on("click", ".pc-tab-btn", (e) => {
        e.preventDefault();
        const tab = $(e.currentTarget).data("tab");
        this.switchTab(tab);
      });

      // Pagination
      $(document).on("click", "[data-pc-exp-page]", (e) => {
        e.preventDefault();
        const p = parseInt($(e.currentTarget).attr("data-pc-exp-page"), 10);
        if (!p) return;
        this.state.page = p;
        this.loadList();
      });
    }

    setListLoading(isLoading) {
      if (isLoading) {
        this.$loading.show();
        this.$table.hide();
        this.$empty.hide();
      } else {
        this.$loading.hide();
      }
    }

    loadList() {
      this.setListLoading(true);
      return this.ajax("pc_experience_get_list", {
        page: this.state.page,
        per_page: this.state.per_page,
        search: this.state.search,
        status: this.state.status,
        availability: this.state.availability,
      })
        .done((res) => {
          if (!res || !res.success) {
            this.renderEmpty();
            alert(res?.data?.message || "Erreur lors du chargement");
            return;
          }
          this.renderList(res.data.items || []);
          this.renderPagination(res.data.pagination || {});
        })
        .fail(() => {
          this.renderEmpty();
          alert("Erreur de communication serveur");
        })
        .always(() => {
          this.setListLoading(false);
        });
    }

    renderEmpty() {
      this.$tbody.empty();
      this.$table.hide();
      this.$empty.show();
      this.$pagination.empty();
    }

    renderList(items) {
      this.$tbody.empty();

      if (!items.length) {
        this.renderEmpty();
        return;
      }

      items.forEach((it) => {
        const img = it.featured_image
          ? `<img src="${this.escAttr(it.featured_image)}" class="pc-thumb" alt="">`
          : `<div class="pc-thumb pc-thumb--empty">🎯</div>`;

        const price = it.price_from ? this.esc(it.price_from) : "—";
        const duration = it.duration ? this.esc(String(it.duration)) + " h" : "—";

        this.$tbody.append(`
          <tr>
            <td class="pc-col-image">${img}</td>
            <td class="pc-col-name">
              <div class="pc-exp-title">${this.esc(it.title)}</div>
              ${it.availability ? `<div class="pc-exp-meta">${this.esc(it.availability)}</div>` : ""}
            </td>
            <td class="pc-col-price">${price}</td>
            <td class="pc-col-duration">${duration}</td>
            <td class="pc-col-status"><span class="pc-badge">${this.esc(it.status)}</span></td>
            <td class="pc-col-actions">
              <button class="pc-btn pc-btn-secondary pc-btn-edit-experience" data-id="${it.id}">Éditer</button>
              <button class="pc-btn pc-btn-danger pc-btn-delete-experience" data-id="${it.id}">Supprimer</button>
            </td>
          </tr>
        `);
      });

      this.$empty.hide();
      this.$table.show();
    }

    renderPagination(p) {
      const page = p.page || 1;
      const totalPages = p.total_pages || 1;

      if (totalPages <= 1) {
        this.$pagination.empty();
        return;
      }

      const btn = (label, target, disabled) => {
        const dis = disabled ? 'aria-disabled="true" class="pc-page-btn disabled"' : 'class="pc-page-btn"';
        const attr = disabled ? "" : `data-pc-exp-page="${target}"`;
        return `<a href="#" ${dis} ${attr}>${label}</a>`;
      };

      let html = "";
      html += btn("←", page - 1, page <= 1);

      // windowed pages
      const start = Math.max(1, page - 2);
      const end = Math.min(totalPages, page + 2);
      for (let i = start; i <= end; i++) {
        html += btn(i, i, i === page);
      }

      html += btn("→", page + 1, page >= totalPages);
      this.$pagination.html(html);
    }

    openNew() {
      this.current = {
        id: 0,
        title: "",
        status: "publish",
        content: "",
        exp_capacite: "",
        exp_duree: "",
        exp_availability: "InStock",
      };
      this.openModal("Nouvelle expérience");
      this.fillForm(this.current);
    }

    openEdit(id) {
      this.openModal("Chargement...");
      this.setModalLoading(true);

      this.ajax("pc_experience_get_details", { post_id: id })
        .done((res) => {
          if (!res || !res.success) {
            alert(res?.data?.message || "Erreur chargement détails");
            this.closeModal();
            return;
          }
          this.current = res.data;
          this.$modalTitle.text(`Édition: ${this.current.title || "Expérience"}`);
          this.fillForm(this.current);
          this.setModalLoading(false);
        })
        .fail(() => {
          alert("Erreur de communication serveur");
          this.closeModal();
        });
    }

    openModal(title) {
      this.$modalTitle.text(title);
      this.$modal.removeClass("hidden");
      this.switchTab("general");
      // toggle delete button
      $("#pc-experience-delete-btn").toggle(!!(this.current && this.current.id));
    }

    closeModal() {
      this.$modal.addClass("hidden");
      this.current = null;
    }

    setModalLoading(isLoading) {
      if (isLoading) {
        this.$modalLoading.show();
        this.$modalDetails.hide();
      } else {
        this.$modalLoading.hide();
        this.$modalDetails.show();
      }
    }

    switchTab(tab) {
      $(".pc-tab-btn").removeClass("active");
      $(`.pc-tab-btn[data-tab='${tab}']`).addClass("active");

      $(".pc-tab-content").removeClass("active").hide();
      $(`#tab-${tab}`).addClass("active").show();
    }

    fillForm(d) {
      // Général
      $("#experience-title").val(d.title || "");
      $("#experience-status").val(d.status || "publish");
      $("#experience-description").val(d.content || "");

      $("#experience-capacity").val(d.exp_capacite ?? "");
      $("#experience-duration").val(d.exp_duree ?? "");
      $("#experience-availability").val(d.exp_availability || "InStock");

      // Détails sorties: âge minimum
      if ($("#experience-min-age").length) {
        $("#experience-min-age").val(d.exp_age_minimum ?? "");
      }

      // SEO (si inputs existent)
      if ($("#experience-meta-title").length) {
        $("#experience-meta-title").val(d.exp_meta_titre || "");
      }
      if ($("#experience-meta-description").length) {
        $("#experience-meta-description").val(d.exp_meta_description || "");
      }

      // Delete button
      $("#pc-experience-delete-btn").toggle(!!d.id);
    }

    collectPayload() {
      const payload = {};
      payload.id = this.current?.id || 0;

      payload.title = ($("#experience-title").val() || "").trim();
      payload.status = $("#experience-status").val() || "publish";
      payload.content = $("#experience-description").val() || "";

      payload.exp_capacite = $("#experience-capacity").val();
      payload.exp_duree = $("#experience-duration").val();
      payload.exp_availability = $("#experience-availability").val() || "InStock";

      if ($("#experience-min-age").length) {
        payload.exp_age_minimum = $("#experience-min-age").val();
      }

      // SEO (si présents)
      if ($("#experience-meta-title").length) payload.exp_meta_titre = $("#experience-meta-title").val();
      if ($("#experience-meta-description").length) payload.exp_meta_description = $("#experience-meta-description").val();

      return payload;
    }

    save() {
      const payload = this.collectPayload();
      if (!payload.title) {
        alert("Le titre est obligatoire");
        this.switchTab("general");
        $("#experience-title").focus();
        return;
      }

      this.toggleButtonLoading("#pc-experience-save-btn", true);

      this.ajax("pc_experience_save", { payload: JSON.stringify(payload) })
        .done((res) => {
          if (!res || !res.success) {
            alert(res?.data?.message || "Erreur sauvegarde");
            return;
          }
          // update current id
          this.current.id = res.data.id;
          this.closeModal();
          this.loadList();
        })
        .fail(() => {
          alert("Erreur de communication serveur");
        })
        .always(() => {
          this.toggleButtonLoading("#pc-experience-save-btn", false);
        });
    }

    delete(id, fromModal = false) {
      if (!confirm("Supprimer cette expérience définitivement ?")) return;

      const btnSel = fromModal ? "#pc-experience-delete-btn" : null;
      if (btnSel) this.toggleButtonLoading(btnSel, true);

      this.ajax("pc_experience_delete", { post_id: id })
        .done((res) => {
          if (!res || !res.success) {
            alert(res?.data?.message || "Erreur suppression");
            return;
          }
          if (fromModal) this.closeModal();
          this.loadList();
        })
        .fail(() => alert("Erreur de communication serveur"))
        .always(() => {
          if (btnSel) this.toggleButtonLoading(btnSel, false);
        });
    }

    toggleButtonLoading(selector, isLoading) {
      const $btn = $(selector);
      const $text = $btn.find(".pc-btn-text");
      const $sp = $btn.find(".pc-btn-spinner");
      if (!$text.length || !$sp.length) return;
      if (isLoading) {
        $text.hide();
        $sp.show();
        $btn.prop("disabled", true);
      } else {
        $text.show();
        $sp.hide();
        $btn.prop("disabled", false);
      }
    }

    debounce(fn, delay) {
      let t = null;
      return (...args) => {
        clearTimeout(t);
        t = setTimeout(() => fn.apply(this, args), delay);
      };
    }

    esc(s) {
      return String(s || "").replace(/[&<>"']/g, (m) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#039;" }[m]));
    }

    escAttr(s) {
      return this.esc(s).replace(/\s/g, "%20");
    }
  }

  $(document).ready(() => {
    // On s'assure que le shortcode est bien présent avant d'instancier
    if ($(".pc-experience-manager").length) {
      new PCExperienceDashboard();
    }
  });
})(jQuery);
