<?php
if (!defined('ABSPATH')) { exit; }

/**
 * PCR_Experience_Manager
 * Nouvelle implémentation "clean" (style Housing): 1 classe, 4 endpoints AJAX.
 * CPT: experience | Stockage: WordPress + ACF (pas de tables custom)
 */
class PCR_Experience_Manager
{
    public static function init(): void
    {
        add_action('wp_ajax_pc_experience_get_list', [__CLASS__, 'ajax_get_list']);
        add_action('wp_ajax_pc_experience_get_details', [__CLASS__, 'ajax_get_details']);
        add_action('wp_ajax_pc_experience_save', [__CLASS__, 'ajax_save']);
        add_action('wp_ajax_pc_experience_delete', [__CLASS__, 'ajax_delete']);
    }

    /* =========================
     * ACF FIELD KEYS (source: group_66dcc7e9c5a16.json)
     * ========================= */
    private static function acf_field_keys(): array
    {
        return [
            // SEO & Liaisons
            'exp_exclude_sitemap' => 'field_68db7babdb30a',
            'exp_http_410' => 'field_68db7bf4db30b',
            'exp_meta_titre' => 'field_66dcc831d111b',
            'exp_meta_description' => 'field_66dcc867d111c',
            'exp_meta_canonical' => 'field_68db7c44db30c',
            'exp_meta_robots' => 'field_68db7ca7db30d',
            'exp_logements_recommandes' => 'field_66dcc8a4d111d',
            'exp_availability' => 'field_68d509f885264',

            // Détails principaux
            'exp_h1_custom' => 'field_68beb1671e633',
            'exp_hero_desktop' => 'field_68beb1cd1e634',
            'exp_hero_mobile' => 'field_68beb2221e635',

            // Détails sorties
            'exp_duree' => 'field_66dcc94cd111f',
            'exp_capacite' => 'field_66dcc9a3d1120',
            'exp_age_minimum' => 'field_66dcc9f9d1121',
            'exp_accessibilite' => 'field_66dcca37d1122',
            'exp_periode' => 'field_68bec10e3bc0f',
            'exp_jour' => 'field_68bf09049c6ae',
            'exp_periodes_fermeture' => 'field_66dccab9d1123',
            'exp_lieux_horaires_depart' => 'field_66dccb67d1126',

            // Inclusions
            'exp_prix_comprend' => 'field_66dcccc2d112c',
            'exp_prix_ne_comprend_pas' => 'field_66dccd1cd112d',
            'exp_a_prevoir' => 'field_66dccd4dd112e',

            // Services
            'exp_delai_de_reservation' => 'field_68dcd02002938',
            'exp_zone_intervention' => 'field_68dcd26402939',
            'exp_type_de_prestation' => 'field_68dcd3f60293a',
            'exp_heure_limite_de_commande' => 'field_68dcd5180293b',
            'exp_le_service_comprend' => 'field_68dce6573eeb6',
            'exp_service_a_prevoir' => 'field_68dce6ca3eeb7',

            // Médias
            'photos_experience' => 'field_66dccda9d1130',

            // FAQ
            'exp_faq' => 'field_66dcce25d1132',

            // Tarifs
            'exp_types_de_tarifs' => 'field_66dcceddd1136',

            // Channel manager
            'taux_tva' => 'field_692db668fa552',
            'regles_de_paiement' => 'field_6919d3b37ec50',
        ];
    }

    /* =========================
     * SECURITY
     * ========================= */
    private static function assert_nonce(): void
    {
        $nonce = $_POST['nonce'] ?? '';
        if (!wp_verify_nonce($nonce, 'pc_resa_manual_create')) {
            wp_send_json_error(['message' => 'Nonce invalide.'], 403);
        }
    }

    private static function assert_caps(): void
    {
        // Aligné sur le shortcode : admin-only
        if (!is_user_logged_in() || !current_user_can('manage_options')) {
            wp_send_json_error(['message' => 'Accès non autorisé.'], 403);
        }
    }

    /* =========================
     * AJAX
     * ========================= */
    public static function ajax_get_list(): void
    {
        self::assert_nonce();
        self::assert_caps();

        $page = max(1, (int)($_POST['page'] ?? 1));
        $per_page = min(50, max(5, (int)($_POST['per_page'] ?? 20)));
        $search = sanitize_text_field($_POST['search'] ?? '');
        $status = sanitize_text_field($_POST['status'] ?? '');
        $availability = sanitize_text_field($_POST['availability'] ?? '');

        $result = self::get_list($page, $per_page, $search, $status, $availability);
        wp_send_json_success($result);
    }

    public static function ajax_get_details(): void
    {
        self::assert_nonce();
        self::assert_caps();

        $post_id = (int)($_POST['post_id'] ?? 0);
        $result = self::get_details($post_id);
        if (!$result['success']) {
            wp_send_json_error($result, 400);
        }
        wp_send_json_success($result['data']);
    }

    public static function ajax_save(): void
    {
        self::assert_nonce();
        self::assert_caps();

        $payload = $_POST['payload'] ?? [];
        if (is_string($payload)) {
            $decoded = json_decode(stripslashes($payload), true);
            if (is_array($decoded)) {
                $payload = $decoded;
            }
        }
        if (!is_array($payload)) {
            wp_send_json_error(['message' => 'Payload invalide.'], 400);
        }

        $result = self::save($payload);
        if (!$result['success']) {
            wp_send_json_error($result, 400);
        }
        wp_send_json_success($result['data']);
    }

    public static function ajax_delete(): void
    {
        self::assert_nonce();
        self::assert_caps();

        $post_id = (int)($_POST['post_id'] ?? 0);
        $result = self::delete($post_id);
        if (!$result['success']) {
            wp_send_json_error($result, 400);
        }
        wp_send_json_success(['message' => 'Supprimé']);
    }

    /* =========================
     * CORE
     * ========================= */

    private static function get_list(int $page, int $per_page, string $search, string $status, string $availability): array
    {
        $args = [
            'post_type' => 'experience',
            'post_status' => ($status !== '' ? $status : ['publish', 'draft', 'pending', 'private']),
            'paged' => $page,
            'posts_per_page' => $per_page,
            'orderby' => 'date',
            'order' => 'DESC',
        ];
        if ($search !== '') {
            $args['s'] = $search;
        }
        if ($availability !== '') {
            $args['meta_query'] = [[
                'key' => 'exp_availability',
                'value' => $availability,
                'compare' => '=',
            ]];
        }

        $q = new WP_Query($args);

        $items = [];
        foreach ($q->posts as $p) {
            $price_from = self::compute_price_from($p->ID);
            $items[] = [
                'id' => (int)$p->ID,
                'title' => $p->post_title,
                'status' => $p->post_status,
                'availability' => function_exists('get_field') ? (get_field('exp_availability', $p->ID) ?: '') : '',
                'duration' => function_exists('get_field') ? (get_field('exp_duree', $p->ID) ?: '') : '',
                'price_from' => $price_from,
                'featured_image' => get_the_post_thumbnail_url($p->ID, 'medium') ?: '',
            ];
        }

        return [
            'items' => $items,
            'pagination' => [
                'page' => $page,
                'per_page' => $per_page,
                'total' => (int)$q->found_posts,
                'total_pages' => (int)$q->max_num_pages,
            ],
        ];
    }

    private static function get_details(int $post_id): array
    {
        if ($post_id <= 0) return ['success' => false, 'message' => 'ID invalide.'];

        $post = get_post($post_id);
        if (!$post || $post->post_type !== 'experience') {
            return ['success' => false, 'message' => 'Expérience introuvable.'];
        }

        $data = [
            'id' => (int)$post_id,
            'title' => $post->post_title,
            'status' => $post->post_status,
            'content' => $post->post_content,
        ];

        if (function_exists('get_field')) {
            foreach (array_keys(self::acf_field_keys()) as $name) {
                $data[$name] = get_field($name, $post_id);
            }
        }

        return ['success' => true, 'data' => $data];
    }

    private static function save(array $payload): array
    {
        $post_id = (int)($payload['id'] ?? 0);
        $title = sanitize_text_field($payload['title'] ?? '');

        if ($title === '') {
            return ['success' => false, 'message' => 'Le titre est obligatoire.'];
        }

        $status = sanitize_text_field($payload['status'] ?? 'publish');
        if (!in_array($status, ['publish', 'draft', 'pending', 'private'], true)) {
            $status = 'publish';
        }

        $postarr = [
            'post_type' => 'experience',
            'post_title' => $title,
            'post_status' => $status,
            'post_content' => wp_kses_post($payload['content'] ?? ''),
        ];

        $result_id = 0;
        if ($post_id > 0) {
            $postarr['ID'] = $post_id;
            $res = wp_update_post($postarr, true);
            if (is_wp_error($res)) {
                return ['success' => false, 'message' => $res->get_error_message()];
            }
            $result_id = (int)$res;
        } else {
            $res = wp_insert_post($postarr, true);
            if (is_wp_error($res)) {
                return ['success' => false, 'message' => $res->get_error_message()];
            }
            $result_id = (int)$res;
        }

        // ACF
        if (function_exists('update_field')) {
            foreach (self::acf_field_keys() as $name => $field_key) {
                if (!array_key_exists($name, $payload)) continue;

                $value = $payload[$name];

                // Petites normalisations
                if ($name === 'exp_duree' && $value !== '' && $value !== null) {
                    $value = is_numeric($value) ? (float)$value : '';
                }
                if ($name === 'exp_capacite' && $value !== '' && $value !== null) {
                    $value = is_numeric($value) ? max(1, (int)$value) : '';
                }

                update_field($field_key, $value, $result_id);
            }
        }

        return ['success' => true, 'data' => ['id' => $result_id]];
    }

    private static function delete(int $post_id): array
    {
        if ($post_id <= 0) return ['success' => false, 'message' => 'ID invalide.'];
        $post = get_post($post_id);
        if (!$post || $post->post_type !== 'experience') {
            return ['success' => false, 'message' => 'Expérience introuvable.'];
        }
        $deleted = wp_delete_post($post_id, true);
        if (!$deleted) return ['success' => false, 'message' => 'Échec suppression.'];
        return ['success' => true];
    }

    /**
     * Prix "à partir de" : calcule le minimum dans exp_types_de_tarifs/exp_tarifs_lignes[*].tarif_valeur
     */
    private static function compute_price_from(int $post_id): string
    {
        if (!function_exists('get_field')) return '';

        $types = get_field('exp_types_de_tarifs', $post_id);
        if (!is_array($types) || empty($types)) return '';

        $min = null;
        foreach ($types as $t) {
            if (!is_array($t)) continue;
            $lines = $t['exp_tarifs_lignes'] ?? null;
            if (!is_array($lines)) continue;
            foreach ($lines as $ln) {
                if (!is_array($ln)) continue;
                $val = $ln['tarif_valeur'] ?? null;
                if ($val === null || $val === '') continue;
                if (!is_numeric($val)) continue;
                $v = (float)$val;
                if ($min === null || $v < $min) $min = $v;
            }
        }
        if ($min === null) return '';
        return number_format($min, 2, ',', ' ') . ' €';
    }
}
